{
  "manifest_version": 3,
  "name": "Antigravity - Tweet Screenshot Customizer",
  "version": "1.0.0",
  "description": "Instantly turn any X (Twitter) post into a premium screenshot graphic with one click.",
  "permissions": ["activeTab"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://twitter.com/*",
        "https://x.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
